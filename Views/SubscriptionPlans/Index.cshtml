@model List<SubscriptionPlan>
@{ ViewData["Title"] = "Subscription Plans"; }
<div class="page-header"><div><span class="eyebrow">Platform</span><h1>Subscription Plans</h1></div><a class="btn btn-primary" asp-action="Create">Create Plan</a></div>
<div class="row g-3">@foreach(var plan in Model){<div class="col-md-6 col-xl-3"><div class="card h-100"><div class="card-body"><h4>@plan.PlanName</h4><p>@plan.Description</p><h3>₹@plan.MonthlyPrice<small class="fs-6">/mo</small></h3><p>Users: @(plan.MaxUsers == 0 ? "Unlimited" : plan.MaxUsers)</p><p>Invoices: @(plan.MaxInvoicesPerMonth == 0 ? "Unlimited" : plan.MaxInvoicesPerMonth)</p><span class="badge bg-@(plan.IsActive ? "success" : "secondary")">@(plan.IsActive ? "Active" : "Inactive")</span></div><div class="card-footer"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@plan.Id">Edit</a><form asp-action="Toggle" asp-route-id="@plan.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-warning">Toggle</button></form></div></div></div>}</div>
