@model LoginViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Advanced GST</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-body">
    <main class="login-page-wrapper">
        <div class="login-bg-shape shape-one"></div>
        <div class="login-bg-shape shape-two"></div>
        <div class="login-bg-shape shape-three"></div>

        <div class="container-fluid login-container">
            <div class="login-shell">
                <section class="login-brand-panel" aria-label="GST software highlights">
                    <div class="brand-content">
                        <div class="brand-pill"><i class="bi bi-shield-check"></i> 100% GST Ready SaaS Platform</div>
                        <h1>GST Billing &amp; Compliance Made Simple</h1>
                        <p class="brand-description">
                            Create GST invoices, track input tax credit, monitor GST payable, prepare returns, and manage business compliance with a clean and powerful software solution.
                        </p>

                        <div class="feature-grid">
                            <div class="feature-item">
                                <span class="feature-icon"><i class="bi bi-receipt"></i></span>
                                <div>
                                    <h2>Smart Billing</h2>
                                    <p>Create accurate GST invoices with automatic tax calculation.</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <span class="feature-icon"><i class="bi bi-journal-check"></i></span>
                                <div>
                                    <h2>Compliance Ready</h2>
                                    <p>Prepare GSTR-1, GSTR-3B, GST challans, and tax summaries.</p>
                                </div>
                            </div>
                            <div class="feature-item">
                                <span class="feature-icon"><i class="bi bi-graph-up-arrow"></i></span>
                                <div>
                                    <h2>Business Insights</h2>
                                    <p>Track sales, purchases, ITC, GST payable, and customer outstanding in one dashboard.</p>
                                </div>
                            </div>
                        </div>

                        <ul class="gst-capability-list" aria-label="GST billing and compliance features">
                            <li><i class="bi bi-check2-circle"></i> Smart GST Invoice Creation</li>
                            <li><i class="bi bi-check2-circle"></i> Auto CGST / SGST / IGST Calculation</li>
                            <li><i class="bi bi-check2-circle"></i> GSTR-1 &amp; GSTR-3B Reports</li>
                            <li><i class="bi bi-check2-circle"></i> E-Invoice &amp; E-Way Bill Ready</li>
                            <li><i class="bi bi-check2-circle"></i> GST Payable &amp; ITC Tracking</li>
                            <li><i class="bi bi-check2-circle"></i> Professional PDF Invoice Generation</li>
                        </ul>

                        <div class="benefit-cards">
                            <div class="benefit-card">
                                <strong>100%</strong>
                                <span>GST Ready</span>
                            </div>
                            <div class="benefit-card">
                                <strong><i class="bi bi-lightning-charge-fill"></i></strong>
                                <span>Fast Invoice Creation</span>
                            </div>
                            <div class="benefit-card">
                                <strong><i class="bi bi-lock-fill"></i></strong>
                                <span>Secure Business Data</span>
                            </div>
                        </div>
                    </div>

                    <div class="login-illustration" aria-hidden="true">
                        <div class="orb orb-primary"></div>
                        <div class="orb orb-accent"></div>
                        <div class="floating-card invoice-card">
                            <div class="invoice-topline">
                                <span>Tax Invoice</span>
                                <span class="gst-badge">GST</span>
                            </div>
                            <div class="invoice-line w-100"></div>
                            <div class="invoice-line w-75"></div>
                            <div class="invoice-line w-50"></div>
                            <div class="invoice-total"><span>Total</span><strong>₹48,250</strong></div>
                        </div>
                        <div class="floating-card chart-card">
                            <div class="chart-title">GST Payable</div>
                            <div class="bar-chart">
                                <span class="bar-sm"></span>
                                <span class="bar-lg"></span>
                                <span class="bar-md"></span>
                                <span class="bar-xl"></span>
                            </div>
                        </div>
                        <div class="floating-card tax-card">
                            <i class="bi bi-file-earmark-check"></i>
                            <span>Returns Ready</span>
                        </div>
                        <div class="rupee-chip">₹</div>
                        <div class="dot-pattern"></div>
                    </div>
                </section>

                <section class="login-form-panel" aria-label="Secure login form">
                    <div class="login-card">
                        <div class="login-card-header text-center">
                            <div class="login-logo mx-auto"><i class="bi bi-receipt-cutoff"></i></div>
                            <span class="secure-kicker"><i class="bi bi-lock-fill"></i> Secure sign in</span>
                            <h2>Welcome Back</h2>
                            <p>Sign in to access your GST dashboard and continue managing your business.</p>
                        </div>

                        <form asp-action="Login" method="post" class="login-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger validation-summary mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <div class="input-icon-group">
                                    <i class="bi bi-envelope"></i>
                                    <input asp-for="Email" class="form-control" placeholder="admin@gstsoftware.com" autocomplete="username" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger field-validation"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label"></label>
                                <div class="input-icon-group">
                                    <i class="bi bi-key"></i>
                                    <input asp-for="Password" class="form-control" placeholder="Enter your password" autocomplete="current-password" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger field-validation"></span>
                            </div>

                            <div class="login-options mb-4">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" />
                                    <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                                </div>
                            </div>

                            <button class="btn login-submit-btn" type="submit">
                                <span>Sign In Securely</span>
                                <i class="bi bi-arrow-right-circle"></i>
                            </button>
                            <div class="text-center mt-3">
                                <a href="/Account/RegisterTenant" class="fw-semibold">Register a new business tenant</a>
                            </div>

                            <div class="demo-credentials" aria-label="Demo credentials">
                                <div class="demo-icon"><i class="bi bi-info-circle"></i></div>
                                <div>
                                    <strong>Demo credentials</strong>
                                    <span>Email: admin@gstsoftware.com</span>
                                    <span>Password: Admin@123</span>
                                    <small>Seed account: admin@advancedgst.local / Admin@12345</small>
                                </div>
                            </div>
                        </form>
                    </div>
                </section>
            </div>
        </div>
    </main>
</body>
</html>
