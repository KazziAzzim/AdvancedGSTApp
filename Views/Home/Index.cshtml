@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Executive overview</div>
        <h1 class="page-title">GST Dashboard</h1>
        <p class="page-subtitle">Monitor sales, purchases, tax credits, pending returns, and recent compliance activity from one polished workspace.</p>
    </div>
    <a class="btn btn-primary" asp-controller="SalesInvoices" asp-action="Create"><i class="bi bi-plus-circle"></i> New Invoice</a>
</div>

<div class="row g-3">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <span class="stat-label">Total Sales</span>
            <h3 class="stat-value">₹@Model.TotalSalesAmount.ToString("N2")</h3>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-bag-check"></i></div>
            <span class="stat-label">Total Purchases</span>
            <h3 class="stat-value">₹@Model.TotalPurchaseAmount.ToString("N2")</h3>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-shield-check"></i></div>
            <span class="stat-label">Input Tax Credit</span>
            <h3 class="stat-value">₹@Model.TotalInputTaxCredit.ToString("N2")</h3>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card grand-total">
            <div class="stat-icon"><i class="bi bi-calendar2-check"></i></div>
            <span class="stat-label">Pending GST Returns</span>
            <h3 class="stat-value">@Model.PendingGstReturns</h3>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-8">
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="mb-1">Recent Sales Invoices</h5>
                    <p class="text-muted mb-0">Latest invoices with customer totals.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="SalesInvoices" asp-action="Index"><i class="bi bi-eye"></i> View all</a>
            </div>
            <partial name="_SalesTable" model="Model.RecentSalesInvoices" />
        </div>
    </div>
    <div class="col-lg-4">
        <div class="section-card h-100">
            <h5 class="mb-1">E-Invoice Status</h5>
            <p class="text-muted">Realtime compliance snapshot for generated invoices.</p>
            @if (Model.EInvoiceStatusSummary.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var status in Model.EInvoiceStatusSummary)
                    {
                        <span class="badge-soft d-inline-flex"><i class="bi bi-lightning-charge-fill"></i> @status.Key @status.Value</span>
                    }
                </div>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-inboxes"></i>No E-Invoice status data yet.</div>
            }
        </div>
    </div>
</div>
