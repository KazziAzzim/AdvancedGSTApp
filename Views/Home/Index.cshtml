@model DashboardViewModel
<h1>Dashboard</h1><div class="row g-3"><div class="col-md-3"><div class="card stat"><div class="card-body"><span>Total Sales</span><h3>₹@Model.TotalSalesAmount.ToString("N2")</h3></div></div></div><div class="col-md-3"><div class="card stat"><div class="card-body"><span>Total Purchases</span><h3>₹@Model.TotalPurchaseAmount.ToString("N2")</h3></div></div></div><div class="col-md-3"><div class="card stat"><div class="card-body"><span>Input Tax Credit</span><h3>₹@Model.TotalInputTaxCredit.ToString("N2")</h3></div></div></div><div class="col-md-3"><div class="card stat"><div class="card-body"><span>Pending Returns</span><h3>@Model.PendingGstReturns</h3></div></div></div></div><div class="row mt-4"><div class="col-md-6"><h4>Recent Sales</h4><partial name="_SalesTable" model="Model.RecentSalesInvoices" /></div><div class="col-md-6"><h4>E-Invoice Status</h4>@foreach(var s in Model.EInvoiceStatusSummary){<span class="badge bg-info me-2">@s.Key @s.Value</span>}</div></div>
