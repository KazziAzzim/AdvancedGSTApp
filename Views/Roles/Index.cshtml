@model RoleListViewModel
@{ ViewData["Title"] = "Role Management"; }
<div class="d-flex justify-content-between align-items-start mb-4"><div><h1 class="h3 mb-1">Role Management</h1><p class="text-muted mb-0">Create custom roles and manage module permissions.</p></div><a asp-action="Create" class="btn btn-primary"><i class="bi bi-shield-plus"></i> Add Role</a></div>
<form class="card border-0 shadow-sm mb-4"><div class="card-body row g-3"><div class="col-md-10"><input name="search" value="@Model.Search" class="form-control" placeholder="Search roles" /></div><div class="col-md-2"><button class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Search</button></div></div></form>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th>Role Name</th><th>Description</th><th>Status</th><th>User Count</th><th>Created</th><th class="text-end">Actions</th></tr></thead><tbody>
@foreach (var role in Model.Roles) {<tr><td class="fw-semibold"><span class="badge text-bg-primary">@role.RoleName</span></td><td>@role.Description</td><td><span class="badge @(role.IsActive ? "text-bg-success" : "text-bg-secondary")">@(role.IsActive ? "Active" : "Inactive")</span></td><td>@role.UserCount</td><td>@role.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</td><td class="text-end"><div class="btn-group btn-group-sm"><a asp-action="Details" asp-route-id="@role.Id" class="btn btn-outline-secondary"><i class="bi bi-eye"></i></a><a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a><a asp-action="ManagePermissions" asp-route-id="@role.Id" class="btn btn-outline-success"><i class="bi bi-sliders"></i></a><form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline"><button class="btn btn-outline-danger" onclick="return confirm('Delete this role?')"><i class="bi bi-trash"></i></button></form></div></td></tr>}
</tbody></table></div></div>
