@model RoleDetailsViewModel
@{ ViewData["Title"] = "Role Details"; }
<div class="d-flex justify-content-between mb-4"><div><h1 class="h3">Role Details</h1><p class="text-muted">Review role status and assigned users.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Back</a></div>
<div class="card border-0 shadow-sm"><div class="card-body row g-3"><div class="col-md-6"><strong>Role Name</strong><div>@Model.RoleName</div></div><div class="col-md-6"><strong>Status</strong><div><span class="badge @(Model.IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></div></div><div class="col-12"><strong>Description</strong><div>@Model.Description</div></div><div class="col-md-4"><strong>User Count</strong><div>@Model.UserCount</div></div><div class="col-md-4"><strong>Created</strong><div>@Model.CreatedDate.ToLocalTime()</div></div><div class="col-md-4"><strong>Updated</strong><div>@Model.UpdatedDate?.ToLocalTime()</div></div></div><div class="card-footer bg-white"><a asp-action="ManagePermissions" asp-route-id="@Model.Id" class="btn btn-success"><i class="bi bi-sliders"></i> Manage Permissions</a></div></div>
