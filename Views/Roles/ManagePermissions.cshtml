@model ManageRolePermissionsViewModel
@{ ViewData["Title"] = "Manage Permissions"; var columns = new[] { "View", "Create", "Edit", "Delete", "Print", "Export", "Email", "Generate", "Approve" }; }
<div class="d-flex justify-content-between mb-4"><div><h1 class="h3">Manage Permissions</h1><p class="text-muted">Configure module-level permissions for <strong>@Model.RoleName</strong>.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Back</a></div>
<form asp-action="ManagePermissions" method="post" class="card border-0 shadow-sm"><input asp-for="RoleId" type="hidden"/><input asp-for="RoleName" type="hidden"/>
<div class="card-body"><div class="mb-3"><button type="button" class="btn btn-sm btn-outline-primary" id="selectAll">Select All</button><button type="button" class="btn btn-sm btn-outline-secondary" id="clearAll">Clear All</button></div><div class="table-responsive"><table class="table table-bordered align-middle permission-table"><thead class="table-light"><tr><th>Module</th><th>Row</th>@for (var c=0;c<columns.Length;c++){<th class="text-center"><label><input type="checkbox" class="column-toggle" data-column="@columns[c]" /> @columns[c]</label></th>}</tr></thead><tbody>
@for (var i=0;i<Model.Permissions.Count;i++) {<tr><td class="fw-semibold"><input asp-for="Permissions[i].Id" type="hidden"/><input asp-for="Permissions[i].ModuleName" type="hidden"/>@Model.Permissions[i].ModuleName</td><td class="text-center"><input type="checkbox" class="row-toggle" /></td><td class="text-center"><input asp-for="Permissions[i].CanView" class="perm View" /></td><td class="text-center"><input asp-for="Permissions[i].CanCreate" class="perm Create" /></td><td class="text-center"><input asp-for="Permissions[i].CanEdit" class="perm Edit" /></td><td class="text-center"><input asp-for="Permissions[i].CanDelete" class="perm Delete" /></td><td class="text-center"><input asp-for="Permissions[i].CanPrint" class="perm Print" /></td><td class="text-center"><input asp-for="Permissions[i].CanExport" class="perm Export" /></td><td class="text-center"><input asp-for="Permissions[i].CanEmail" class="perm Email" /></td><td class="text-center"><input asp-for="Permissions[i].CanGenerate" class="perm Generate" /></td><td class="text-center"><input asp-for="Permissions[i].CanApprove" class="perm Approve" /></td></tr>}
</tbody></table></div></div><div class="card-footer bg-white text-end"><button class="btn btn-primary"><i class="bi bi-save"></i> Save Permissions</button></div></form>
@section Scripts {<script>$(function(){ $('#selectAll').on('click',()=>$('.perm').prop('checked',true)); $('#clearAll').on('click',()=>$('.perm').prop('checked',false)); $('.row-toggle').on('change',function(){$(this).closest('tr').find('.perm').prop('checked',this.checked);}); $('.column-toggle').on('change',function(){$('.'+$(this).data('column')).prop('checked',this.checked);});});</script>}
