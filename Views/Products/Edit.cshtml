@model Product
<h1>Product</h1><form asp-action="Edit" method="post"><input asp-for="Id" type="hidden"/><div class="row"><div class="col-md-3"><label asp-for="ProductCode"></label><input asp-for="ProductCode" class="form-control"/></div><div class="col-md-5"><label asp-for="ProductName"></label><input asp-for="ProductName" class="form-control"/></div><div class="col-md-2"><label asp-for="HSNCode"></label><input asp-for="HSNCode" class="form-control"/></div><div class="col-md-2"><label asp-for="GSTPercentage"></label><input asp-for="GSTPercentage" class="form-control"/></div><div class="col-md-3"><label asp-for="Unit"></label><input asp-for="Unit" class="form-control"/></div><div class="col-md-3"><label asp-for="SaleRate"></label><input asp-for="SaleRate" class="form-control"/></div><div class="col-md-3"><label asp-for="PurchaseRate"></label><input asp-for="PurchaseRate" class="form-control"/></div><div class="col-md-3"><label asp-for="CurrentStock"></label><input asp-for="CurrentStock" class="form-control"/></div></div><button class="btn btn-primary mt-3">Save</button></form>
