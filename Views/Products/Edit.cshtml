@model Product
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Product" : "Edit Product";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Product setup</div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">Configure product rates, HSN codes, GST percentage, and current stock.</p>
    </div>
</div>

<form asp-action="Edit" method="post" class="section-card">
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="ProductCode" class="form-label"></label>
            <input asp-for="ProductCode" class="form-control" />
        </div>
        <div class="col-md-5">
            <label asp-for="ProductName" class="form-label"></label>
            <input asp-for="ProductName" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="HSNCode" class="form-label"></label>
            <input asp-for="HSNCode" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="GSTPercentage" class="form-label"></label>
            <input asp-for="GSTPercentage" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="SaleRate" class="form-label"></label>
            <input asp-for="SaleRate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="PurchaseRate" class="form-label"></label>
            <input asp-for="PurchaseRate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="CurrentStock" class="form-label"></label>
            <input asp-for="CurrentStock" class="form-control" />
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <button class="btn btn-primary"><i class="bi bi-save"></i> Save Product</button>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</form>
