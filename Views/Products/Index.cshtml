@model IEnumerable<Product>
<h1>Products <a class="btn btn-primary btn-sm" asp-action="Create">Add</a></h1><table class="table table-striped data-table"><thead><tr><th>Code</th><th>Name</th><th>HSN</th><th>GST</th><th>Sale Rate</th><th></th></tr></thead><tbody>@foreach(var x in Model){<tr><td>@x.ProductCode</td><td>@x.ProductName</td><td>@x.HSNCode</td><td>@x.GSTPercentage%</td><td>@x.SaleRate</td><td><a asp-action="Edit" asp-route-id="@x.Id">Edit</a><form asp-action="Delete" asp-route-id="@x.Id" method="post" class="d-inline delete-form"><button class="btn btn-link text-danger">Delete</button></form></td></tr>}</tbody></table>
