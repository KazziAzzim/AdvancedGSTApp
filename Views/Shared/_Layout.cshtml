@using AdvancedGSTApp.Services.Interfaces
@using System.Security.Claims
@inject IPermissionService PermissionService
@inject AdvancedGSTApp.Services.Interfaces.ITenantContext TenantContext
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string IsActive(string controller, string? action = null)
    {
        var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatches = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return controllerMatches && actionMatches ? "active" : string.Empty;
    }

    var layoutUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    async Task<bool> CanViewMenu(string moduleName) => User.Identity?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(layoutUserId) && await PermissionService.CanViewAsync(layoutUserId, moduleName);
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Advanced GST</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar" id="appSidebar">
            <div class="brand-panel">
                <div class="brand-mark"><i class="bi bi-receipt-cutoff"></i></div>
                <div>
                    <h4>Advanced GST</h4>
                    <span>Billing & Compliance</span>
                </div>
            </div>

            <nav class="nav sidebar-nav flex-column">
                @if (TenantContext.IsSuperAdmin)
                {
                    <span class="nav-section">Platform</span>
                    <a class="nav-link @IsActive("SuperAdminDashboard")" asp-controller="SuperAdminDashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Platform Dashboard</a>
                    <a class="nav-link @IsActive("Tenants")" asp-controller="Tenants" asp-action="Index"><i class="bi bi-buildings"></i> Tenants</a>
                    <a class="nav-link @IsActive("SubscriptionPlans")" asp-controller="SubscriptionPlans" asp-action="Index"><i class="bi bi-tags"></i> Plans</a>
                    <a class="nav-link @IsActive("TenantSubscriptions")" asp-controller="TenantSubscriptions" asp-action="Index"><i class="bi bi-arrow-repeat"></i> Subscriptions</a>
                    <a class="nav-link @IsActive("SaasPayments")" asp-controller="SaasPayments" asp-action="Index"><i class="bi bi-credit-card"></i> SaaS Payments</a>
                }

                <span class="nav-section">Workspace</span>
                @if (await CanViewMenu("Dashboard")) { <a class="nav-link @IsActive("Home")" asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a> }
                @if (await CanViewMenu("Customers")) { <a class="nav-link @IsActive("Customers")" asp-controller="Customers" asp-action="Index"><i class="bi bi-people-fill"></i> Customers</a> }
                @if (await CanViewMenu("Suppliers")) { <a class="nav-link @IsActive("Suppliers")" asp-controller="Suppliers" asp-action="Index"><i class="bi bi-truck"></i> Suppliers</a> }
                @if (await CanViewMenu("Products")) { <a class="nav-link @IsActive("Products")" asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam-fill"></i> Products</a> }

                <span class="nav-section">Transactions</span>
                @if (await CanViewMenu("Sales Invoice")) { <a class="nav-link @IsActive("SalesInvoices")" asp-controller="SalesInvoices" asp-action="Index"><i class="bi bi-file-earmark-text-fill"></i> Sales Invoices</a> }
                @if (await CanViewMenu("Purchase Invoice")) { <a class="nav-link @IsActive("PurchaseInvoices")" asp-controller="PurchaseInvoices" asp-action="Index"><i class="bi bi-bag-check-fill"></i> Purchases</a> }

                <span class="nav-section">GST Compliance</span>
                @if (await CanViewMenu("GST Payable Summary")) { <a class="nav-link @IsActive("Gst", "PayableSummary")" asp-controller="Gst" asp-action="PayableSummary"><i class="bi bi-cash-coin"></i> GST Payable</a> }
                @if (await CanViewMenu("GSTR-1 Report")) { <a class="nav-link @IsActive("Gst", "Gstr1")" asp-controller="Gst" asp-action="Gstr1"><i class="bi bi-journal-check"></i> GSTR-1</a> }
                @if (await CanViewMenu("GSTR-3B Report")) { <a class="nav-link @IsActive("Gst", "Gstr3B")" asp-controller="Gst" asp-action="Gstr3B"><i class="bi bi-clipboard2-data-fill"></i> GSTR-3B</a> }
                @if (await CanViewMenu("GST Challan")) { <a class="nav-link @IsActive("Gst", "Challan")" asp-controller="Gst" asp-action="Challan"><i class="bi bi-bank2"></i> Challan</a> }
                @if (await CanViewMenu("GST Return Status")) { <a class="nav-link @IsActive("Gst", "ReturnStatus")" asp-controller="Gst" asp-action="ReturnStatus"><i class="bi bi-cloud-check-fill"></i> Return Status</a> }
                @if (await CanViewMenu("Reports")) { <a class="nav-link @IsActive("Reports")" asp-controller="Reports" asp-action="SalesRegister"><i class="bi bi-bar-chart-fill"></i> Reports</a> }

                <span class="nav-section">Administration</span>
                @if (await CanViewMenu("User Management")) { <a class="nav-link @IsActive("Users")" asp-controller="Users" asp-action="Index"><i class="bi bi-person-gear"></i> Users</a> }
                @if (await CanViewMenu("Role Management")) { <a class="nav-link @IsActive("Roles")" asp-controller="Roles" asp-action="Index"><i class="bi bi-shield-lock"></i> Roles</a> }
            </nav>
        </aside>

        <div class="sidebar-backdrop" data-sidebar-close></div>

        <main class="app-main">
            <nav class="topbar navbar navbar-expand-lg">
                <div class="container-fluid px-0">
                    <button class="btn btn-icon d-lg-none" type="button" data-sidebar-toggle aria-label="Toggle navigation">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="topbar-title">
                        <span class="eyebrow">Professional SaaS Workspace</span>
                        <strong>GST Billing & Compliance</strong>
                    </div>
                    <div class="ms-auto d-flex align-items-center gap-2">
                        @if (TenantContext.IsSuperAdmin)
                        {
                            <span class="status-pill d-none d-md-inline-flex"><i class="bi bi-shield-check"></i> Platform Admin</span>
                        }
                        else
                        {
                            <span class="status-pill d-none d-md-inline-flex"><i class="bi bi-building"></i> @(TenantContext.TenantName ?? "Tenant Workspace")</span>
                        }
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </nav>

            <section class="content-area">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-modern"><i class="bi bi-check-circle-fill"></i> @TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-modern"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]</div>
                }

                @RenderBody()
            </section>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
