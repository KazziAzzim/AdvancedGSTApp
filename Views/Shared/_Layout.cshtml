<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Advanced GST</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/><link rel="stylesheet" href="~/css/site.css" /></head><body><div class="d-flex"><aside class="sidebar p-3 bg-dark text-white"><h4>Advanced GST</h4><nav class="nav flex-column"><a class="nav-link text-white" asp-controller="Home" asp-action="Index">Dashboard</a><a class="nav-link text-white" asp-controller="Customers" asp-action="Index">Customers</a><a class="nav-link text-white" asp-controller="Suppliers" asp-action="Index">Suppliers</a><a class="nav-link text-white" asp-controller="Products" asp-action="Index">Products</a><a class="nav-link text-white" asp-controller="SalesInvoices" asp-action="Index">Sales Invoices</a><a class="nav-link text-white" asp-controller="PurchaseInvoices" asp-action="Index">Purchases</a><a class="nav-link text-white" asp-controller="Gst" asp-action="PayableSummary">GST Payable</a><a class="nav-link text-white" asp-controller="Gst" asp-action="Gstr1">GSTR-1</a><a class="nav-link text-white" asp-controller="Gst" asp-action="Gstr3B">GSTR-3B</a><a class="nav-link text-white" asp-controller="Reports" asp-action="SalesRegister">Reports</a></nav></aside><main class="flex-grow-1"><nav class="navbar navbar-light bg-light px-3"><span class="navbar-brand">GST Billing & Compliance</span><a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary btn-sm">Logout</a></nav><section class="container-fluid p-4">@if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}@if(TempData["Error"]!=null){<div class="alert alert-danger">@TempData["Error"]</div>}@RenderBody()</section></main></div><script src="https://code.jquery.com/jquery-3.7.1.min.js"></script><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script><script src="~/js/site.js"></script>@await RenderSectionAsync("Scripts", false)</body></html>
