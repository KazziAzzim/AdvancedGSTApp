@model IEnumerable<SalesInvoice>
<h1>Sales Invoices <a class="btn btn-primary btn-sm" asp-action="Create">Create</a></h1><table class="table table-striped data-table"><thead><tr><th>No</th><th>Date</th><th>Customer</th><th>Taxable</th><th>GST</th><th>Total</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var x in Model){<tr><td>@x.InvoiceNumber</td><td>@x.InvoiceDate.ToShortDateString()</td><td>@x.Customer?.CustomerName</td><td>@x.TaxableAmount</td><td>@x.TotalGSTAmount</td><td>@x.GrandTotal</td><td><span class="badge bg-secondary">@x.EInvoiceStatus</span></td><td><a asp-action="Details" asp-route-id="@x.Id">View</a></td></tr>}</tbody></table>
