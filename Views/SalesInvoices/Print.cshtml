@model TaxInvoicePrintViewModel
@{
    Layout = null;
    var invoice = Model.Invoice;
    var company = Model.Company;
    var customer = Model.Customer;
    var eInvoice = Model.EInvoice;
    var eWayBill = Model.EWayBill;

    string Money(decimal value) => string.Format(new System.Globalization.CultureInfo("en-IN"), "₹{0:N2}", value);
    string DateValue(DateTime? value) => value.HasValue ? value.Value.ToString("dd-MMM-yyyy") : "—";
    string TextValue(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;
    string GstRate(decimal value) => $"{value:0.##}%";
    string QrCodeValue() => TextValue(eInvoice?.SignedQRCode ?? invoice.QRCode);
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tax Invoice @invoice.InvoiceNumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/invoice-print.css" asp-append-version="true" />
</head>
<body class="invoice-print-body">
    <div class="invoice-toolbar no-print">
        <div>
            <div class="toolbar-kicker">Print Preview</div>
            <strong>Tax Invoice @invoice.InvoiceNumber</strong>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
            <a asp-action="DownloadPdf" asp-route-id="@invoice.Id" class="btn btn-outline-success"><i class="bi bi-download"></i> Download PDF</a>
            <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </div>

    <main class="invoice-print-wrapper">
        <section class="tax-invoice-sheet">
            <div class="invoice-copy-label">Original for Recipient</div>
            <header class="invoice-title-band">
                <h1>TAX INVOICE</h1>
                <span>Duplicate for Transporter · Triplicate for Supplier</span>
            </header>

            <section class="invoice-header-grid invoice-section">
                <div class="company-block">
                    <div class="company-logo">
                        @if (!string.IsNullOrWhiteSpace(company?.LogoPath))
                        {
                            <img src="@company.LogoPath" alt="@company.CompanyName logo" />
                        }
                        else
                        {
                            <i class="bi bi-building-check"></i>
                        }
                    </div>
                    <div>
                        <h2>@TextValue(company?.CompanyName)</h2>
                        <p>@TextValue(company?.Address)</p>
                        <p>@TextValue(company?.City) @TextValue(company?.Pincode), @TextValue(company?.State)</p>
                        <div class="meta-line"><strong>GSTIN:</strong> @TextValue(company?.GSTIN)</div>
                        <div class="meta-line"><strong>PAN:</strong> @TextValue(company?.PANNumber)</div>
                    </div>
                </div>
                <div class="company-contact-card">
                    <div><strong>Phone</strong><span>@TextValue(company?.PhoneNumber)</span></div>
                    <div><strong>Email</strong><span>@TextValue(company?.Email)</span></div>
                    <div><strong>State</strong><span>@TextValue(company?.State)</span></div>
                    <div><strong>State Code</strong><span>@TextValue(Model.CompanyStateCode)</span></div>
                </div>
            </section>

            <section class="invoice-info-grid invoice-section">
                <div class="info-box">
                    <span>Invoice No.</span>
                    <strong>@invoice.InvoiceNumber</strong>
                </div>
                <div class="info-box">
                    <span>Invoice Date</span>
                    <strong>@DateValue(invoice.InvoiceDate)</strong>
                </div>
                <div class="info-box">
                    <span>Due Date</span>
                    <strong>—</strong>
                </div>
                <div class="info-box">
                    <span>Place of Supply</span>
                    <strong>@TextValue(invoice.PlaceOfSupply)</strong>
                </div>
                <div class="info-box">
                    <span>Reverse Charge</span>
                    <strong>@(invoice.ReverseChargeApplicable ? "Yes" : "No")</strong>
                </div>
                <div class="info-box">
                    <span>Financial Year</span>
                    <strong>@TextValue(invoice.FinancialYear ?? company?.FinancialYear)</strong>
                </div>
                <div class="info-box">
                    <span>Payment Status</span>
                    <strong>Pending</strong>
                </div>
            </section>

            <section class="party-grid invoice-section">
                <div class="party-card">
                    <h3>Bill To</h3>
                    <strong>@TextValue(customer?.CustomerName)</strong>
                    <p>@TextValue(invoice.BillingAddress)</p>
                    <div class="party-meta"><span>GSTIN</span><b>@TextValue(customer?.GSTIN)</b></div>
                    <div class="party-meta"><span>PAN</span><b>@TextValue(customer?.PANNumber)</b></div>
                    <div class="party-meta"><span>State</span><b>@TextValue(customer?.State)</b></div>
                    <div class="party-meta"><span>State Code</span><b>@TextValue(Model.CustomerStateCode)</b></div>
                    <div class="party-meta"><span>Phone</span><b>@TextValue(customer?.PhoneNumber)</b></div>
                    <div class="party-meta"><span>Email</span><b>@TextValue(customer?.Email)</b></div>
                </div>
                <div class="party-card">
                    <h3>Ship To</h3>
                    <strong>@TextValue(customer?.CustomerName)</strong>
                    <p>@TextValue(Model.ShipToAddress)</p>
                    <div class="party-meta"><span>State</span><b>@TextValue(customer?.State)</b></div>
                    <div class="party-meta"><span>Pincode</span><b>@TextValue(customer?.Pincode)</b></div>
                </div>
            </section>

            <section class="compliance-grid invoice-section">
                <div class="compliance-card">
                    <h3>E-Invoice</h3>
                    @if (Model.HasEInvoice)
                    {
                        <div class="compliance-content">
                            <div>
                                <div class="party-meta"><span>IRN</span><b>@TextValue(eInvoice?.IRNNumber ?? invoice.IRNNumber)</b></div>
                                <div class="party-meta"><span>Ack No.</span><b>@TextValue(eInvoice?.AcknowledgementNumber)</b></div>
                                <div class="party-meta"><span>Ack Date</span><b>@DateValue(eInvoice?.AcknowledgementDate)</b></div>
                                <div class="party-meta"><span>Status</span><b>@TextValue(eInvoice?.Status ?? invoice.EInvoiceStatus)</b></div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(eInvoice?.SignedQRCode ?? invoice.QRCode))
                            {
                                <div class="qr-box">
                                    @if (QrCodeValue().StartsWith("data:image", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <img src="@QrCodeValue()" alt="Signed QR Code" />
                                    }
                                    else
                                    {
                                        <span>@QrCodeValue()</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="not-generated">E-Invoice: Not Generated</div>
                    }
                </div>
                <div class="compliance-card">
                    <h3>E-Way Bill</h3>
                    @if (Model.HasEWayBill)
                    {
                        <div class="party-meta"><span>No.</span><b>@TextValue(eWayBill?.EWayBillNumber ?? invoice.EWayBillNumber)</b></div>
                        <div class="party-meta"><span>Date</span><b>@DateValue(eWayBill?.EWayBillDate)</b></div>
                        <div class="party-meta"><span>Valid From</span><b>@DateValue(eWayBill?.ValidFrom)</b></div>
                        <div class="party-meta"><span>Valid Until</span><b>@DateValue(eWayBill?.ValidUntil)</b></div>
                        <div class="party-meta"><span>Transporter</span><b>@TextValue(eWayBill?.TransporterName)</b></div>
                        <div class="party-meta"><span>Transporter GSTIN</span><b>@TextValue(eWayBill?.TransporterGSTIN)</b></div>
                        <div class="party-meta"><span>Vehicle</span><b>@TextValue(eWayBill?.VehicleNumber)</b></div>
                        <div class="party-meta"><span>Distance</span><b>@(eWayBill is not null && eWayBill.Distance > 0 ? $"{eWayBill.Distance} km" : "—")</b></div>
                        <div class="party-meta"><span>Status</span><b>@TextValue(eWayBill?.Status ?? invoice.EWayBillStatus)</b></div>
                    }
                    else
                    {
                        <div class="not-generated">E-Way Bill: Not Generated</div>
                    }
                </div>
            </section>

            <section class="invoice-section items-section">
                <table class="invoice-items-table">
                    <thead>
                        <tr>
                            <th>Sr.</th>
                            <th>Item / Description</th>
                            <th>HSN/SAC</th>
                            <th>Qty</th>
                            <th>Unit</th>
                            <th>Rate</th>
                            <th>Discount</th>
                            <th>Taxable Value</th>
                            <th>GST %</th>
                            <th>CGST</th>
                            <th>SGST</th>
                            <th>IGST</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];
                            <tr>
                                <td class="text-center">@(i + 1)</td>
                                <td class="description-cell">@item.Description</td>
                                <td>@TextValue(item.HsnSac)</td>
                                <td class="text-center">@item.Quantity.ToString("N2")</td>
                                <td class="text-center">@TextValue(item.Unit)</td>
                                <td class="amount-cell">@Money(item.Rate)</td>
                                <td class="amount-cell">@Money(item.DiscountAmount)</td>
                                <td class="amount-cell">@Money(item.TaxableAmount)</td>
                                <td class="text-center">@GstRate(item.GSTPercentage)</td>
                                <td class="amount-cell">@Money(item.CGSTAmount)</td>
                                <td class="amount-cell">@Money(item.SGSTAmount)</td>
                                <td class="amount-cell">@Money(item.IGSTAmount)</td>
                                <td class="amount-cell fw-bold">@Money(item.LineTotal)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="summary-grid invoice-section">
                <div>
                    <h3 class="section-title">GST Summary</h3>
                    <table class="gst-summary-table">
                        <thead>
                            <tr><th>GST Rate</th><th>Taxable Amount</th><th>CGST Amount</th><th>SGST Amount</th><th>IGST Amount</th><th>Total GST</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.GstSummary)
                            {
                                <tr>
                                    <td>@GstRate(row.GstRate)</td>
                                    <td class="amount-cell">@Money(row.TaxableAmount)</td>
                                    <td class="amount-cell">@Money(row.CgstAmount)</td>
                                    <td class="amount-cell">@Money(row.SgstAmount)</td>
                                    <td class="amount-cell">@Money(row.IgstAmount)</td>
                                    <td class="amount-cell fw-bold">@Money(row.TotalGst)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="totals-card">
                    <div><span>Total Taxable Amount</span><strong>@Money(invoice.TaxableAmount)</strong></div>
                    <div><span>Total Discount</span><strong>@Money(invoice.DiscountAmount)</strong></div>
                    <div><span>Total CGST</span><strong>@Money(invoice.CGSTAmount)</strong></div>
                    <div><span>Total SGST</span><strong>@Money(invoice.SGSTAmount)</strong></div>
                    <div><span>Total IGST</span><strong>@Money(invoice.IGSTAmount)</strong></div>
                    <div><span>Total GST</span><strong>@Money(invoice.TotalGSTAmount)</strong></div>
                    <div><span>Round Off</span><strong>@Money(invoice.RoundOff)</strong></div>
                    <div class="grand-total-row"><span>Grand Total</span><strong>@Money(invoice.GrandTotal)</strong></div>
                </div>
            </section>

            <section class="amount-words invoice-section">
                <strong>Amount in Words:</strong>
                <span>@Model.AmountInWords</span>
            </section>

            <section class="bottom-grid invoice-section">
                <div class="bank-card">
                    <h3>Bank Details</h3>
                    <div class="party-meta"><span>Bank Name</span><b>@TextValue(company?.BankName)</b></div>
                    <div class="party-meta"><span>Account No.</span><b>@TextValue(company?.AccountNumber)</b></div>
                    <div class="party-meta"><span>IFSC</span><b>@TextValue(company?.IFSCCode)</b></div>
                    <div class="party-meta"><span>Branch</span><b>@TextValue(company?.BranchName)</b></div>
                </div>
                <div class="terms-card">
                    <h3>Terms & Conditions</h3>
                    <p>@TextValue(Model.TermsAndConditions)</p>
                    @if (!string.IsNullOrWhiteSpace(invoice.Notes))
                    {
                        <p><strong>Notes:</strong> @invoice.Notes</p>
                    }
                    <p class="declaration">We declare that this invoice shows the actual price of the goods/services described and that all particulars are true and correct.</p>
                </div>
            </section>

            <section class="signature-section invoice-section">
                <div></div>
                <div class="signature-box">
                    <strong>For @TextValue(company?.CompanyName)</strong>
                    <div class="signature-space"></div>
                    <span>Authorized Signatory</span>
                </div>
            </section>

            <footer class="invoice-footer">This is a computer-generated invoice.</footer>
        </section>
    </main>
</body>
</html>
