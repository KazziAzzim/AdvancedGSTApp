@model SalesInvoice
<div class="invoice-print"><div class="d-flex justify-content-between"><h1>GST Invoice</h1><button onclick="window.print()" class="btn btn-outline-secondary no-print">Print</button></div><h4>@Model.InvoiceNumber</h4><p>Date: @Model.InvoiceDate.ToShortDateString() | Place of supply: @Model.PlaceOfSupply</p><p><strong>Customer:</strong> @Model.Customer?.CustomerName<br/>GSTIN: @Model.Customer?.GSTIN<br/>@Model.BillingAddress</p><table class="table table-bordered"><thead><tr><th>Description</th><th>HSN/SAC</th><th>Qty</th><th>Rate</th><th>Taxable</th><th>CGST</th><th>SGST</th><th>IGST</th><th>Total</th></tr></thead><tbody>@foreach(var i in Model.Items){<tr><td>@i.Description</td><td>@i.HsnSac</td><td>@i.Quantity</td><td>@i.Rate</td><td>@i.TaxableAmount</td><td>@i.CGSTAmount</td><td>@i.SGSTAmount</td><td>@i.IGSTAmount</td><td>@i.LineTotal</td></tr>}</tbody></table><div class="text-end"><p>Taxable: ₹@Model.TaxableAmount.ToString("N2")</p><p>GST: ₹@Model.TotalGSTAmount.ToString("N2")</p><h3>Grand Total: ₹@Model.GrandTotal.ToString("N2")</h3><p>@Model.AmountInWords</p></div><p>IRN: @Model.IRNNumber</p><p>QR: @Model.QRCode</p><p>E-Way Bill: @Model.EWayBillNumber</p></div><form asp-action="GenerateEInvoice" asp-route-id="@Model.Id" method="post" class="d-inline no-print"><button class="btn btn-primary">Generate E-Invoice</button></form><form asp-action="GenerateEWayBill" asp-route-id="@Model.Id" method="post" class="d-inline no-print"><button class="btn btn-warning">Generate E-Way Bill</button></form><a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-success no-print">Download PDF</a>
