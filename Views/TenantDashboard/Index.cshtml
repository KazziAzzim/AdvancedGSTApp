@model TenantDashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }
@if (Model.SubscriptionExpiryDate.HasValue && Model.SubscriptionExpiryDate.Value.Date <= DateTime.UtcNow.Date.AddDays(7)) { <div class="alert alert-warning">Your subscription expires on @Model.SubscriptionExpiryDate.Value.ToString("dd MMM yyyy"). Please contact support to renew your plan.</div> }
<div class="page-header"><div><span class="eyebrow">Tenant Workspace</span><h1>Dashboard</h1><p>Current plan: <span class="badge bg-info">@Model.CurrentPlan</span></p></div></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="stat-card"><span>Total sales</span><strong>₹@Model.TotalSales</strong></div></div><div class="col-md-3"><div class="stat-card"><span>Purchases</span><strong>₹@Model.TotalPurchases</strong></div></div><div class="col-md-3"><div class="stat-card"><span>GST payable</span><strong>₹@Model.GstPayable</strong></div></div><div class="col-md-3"><div class="stat-card"><span>ITC</span><strong>₹@Model.Itc</strong></div></div></div>
<div class="row g-3"><div class="col-md-4"><div class="card"><div class="card-body"><h5>Users</h5><p>@Model.Users active users</p></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Customers / Suppliers</h5><p>@Model.Customers customers • @Model.Suppliers suppliers</p></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Invoice usage</h5><p>@Model.InvoiceUsageThisMonth / @(Model.MaxInvoicesPerMonth == 0 ? "∞" : Model.MaxInvoicesPerMonth)</p><div class="progress"><div class="progress-bar" style="width:@(Model.MaxInvoicesPerMonth == 0 ? 5 : Math.Min(100, Model.InvoiceUsageThisMonth * 100 / Math.Max(1, Model.MaxInvoicesPerMonth)))%"></div></div></div></div></div></div>
