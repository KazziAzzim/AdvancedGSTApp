@model IEnumerable<PurchaseInvoice>
<h1>Purchase Invoices <a class="btn btn-primary btn-sm" asp-action="Create">Create</a></h1><table class="table table-striped"><thead><tr><th>No</th><th>Supplier Invoice</th><th>Date</th><th>Supplier</th><th>ITC</th><th>Total</th></tr></thead><tbody>@foreach(var x in Model){<tr><td>@x.PurchaseInvoiceNumber</td><td>@x.SupplierInvoiceNumber</td><td>@x.InvoiceDate.ToShortDateString()</td><td>@x.Supplier?.SupplierName</td><td>@x.ITCEligibleAmount</td><td>@x.GrandTotal</td></tr>}</tbody></table>
