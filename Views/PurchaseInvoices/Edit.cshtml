@model PurchaseInvoice
<h1>Purchase Invoice</h1><form asp-action="Create" method="post"><div class="row"><div class="col-md-3"><label asp-for="PurchaseInvoiceNumber"></label><input asp-for="PurchaseInvoiceNumber" class="form-control"/></div><div class="col-md-3"><label asp-for="SupplierInvoiceNumber"></label><input asp-for="SupplierInvoiceNumber" class="form-control"/></div><div class="col-md-3"><label asp-for="InvoiceDate"></label><input asp-for="InvoiceDate" type="date" class="form-control"/></div><div class="col-md-3"><label asp-for="SupplierId"></label><input asp-for="SupplierId" class="form-control"/></div><div class="col-md-2"><label asp-for="TaxableAmount"></label><input asp-for="TaxableAmount" class="form-control"/></div><div class="col-md-2"><label asp-for="CGSTAmount"></label><input asp-for="CGSTAmount" class="form-control"/></div><div class="col-md-2"><label asp-for="SGSTAmount"></label><input asp-for="SGSTAmount" class="form-control"/></div><div class="col-md-2"><label asp-for="IGSTAmount"></label><input asp-for="IGSTAmount" class="form-control"/></div><div class="col-md-2"><label asp-for="GrandTotal"></label><input asp-for="GrandTotal" class="form-control"/></div></div><button class="btn btn-primary mt-3">Save</button></form>
