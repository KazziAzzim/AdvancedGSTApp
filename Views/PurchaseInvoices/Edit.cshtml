@model PurchaseInvoice
@{
    ViewData["Title"] = "Purchase Invoice";
}

<div class="page-header">
    <div><div class="page-kicker">Purchase entry</div><h1 class="page-title">Purchase Invoice</h1><p class="page-subtitle">Record purchase tax values without changing existing ITC processing logic.</p></div>
</div>

<form asp-action="Create" method="post" class="section-card">
    <div class="row g-3">
        <div class="col-md-3"><label asp-for="PurchaseInvoiceNumber" class="form-label"></label><input asp-for="PurchaseInvoiceNumber" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="SupplierInvoiceNumber" class="form-label"></label><input asp-for="SupplierInvoiceNumber" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="InvoiceDate" class="form-label"></label><input asp-for="InvoiceDate" type="date" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="SupplierId" class="form-label"></label><input asp-for="SupplierId" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="TaxableAmount" class="form-label"></label><input asp-for="TaxableAmount" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="CGSTAmount" class="form-label"></label><input asp-for="CGSTAmount" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="SGSTAmount" class="form-label"></label><input asp-for="SGSTAmount" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="IGSTAmount" class="form-label"></label><input asp-for="IGSTAmount" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="GrandTotal" class="form-label"></label><input asp-for="GrandTotal" class="form-control" /></div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4"><button class="btn btn-primary"><i class="bi bi-save"></i> Save Purchase</button><a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a></div>
</form>
