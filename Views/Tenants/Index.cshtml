@model TenantListViewModel
@{
    ViewData["Title"] = "Tenants";
}
<div class="page-header"><div><span class="eyebrow">Platform</span><h1>Tenants</h1></div><a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle"></i> Create Tenant</a></div>
<form class="row g-2 mb-3"><div class="col-md-4"><input class="form-control" name="search" value="@Model.Search" placeholder="Search business, GSTIN, email" /></div><div class="col-auto"><button class="btn btn-outline-primary">Search</button></div></form>
<div class="card table-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Business Name</th>
                    <th>GSTIN</th>
                    <th>Contact</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>State</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in Model.Tenants)
                {
                    <tr>
                        <td>@tenant.BusinessName</td>
                        <td>@tenant.GSTIN</td>
                        <td>@tenant.ContactPersonName</td>
                        <td>@tenant.Email</td>
                        <td>@tenant.PhoneNumber</td>
                        <td>@tenant.State</td>
                        <td><span class="badge bg-info">@(tenant.SubscriptionPlan?.PlanName ?? "-")</span></td>
                        <td>
                            <span class="badge bg-@(tenant.IsActive ? "success" : "secondary")">@(tenant.IsActive ? "Active" : "Inactive")</span> @if(tenant.IsTrial){
                            <span class="badge bg-warning text-dark">Trial</span>
                        }
                    </td>
                    <td>@tenant.CreatedDate.ToString("dd MMM yyyy")</td>
                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@tenant.Id">Details</a> <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@tenant.Id">Edit</a><form asp-action="@(tenant.IsActive ? "Deactivate" : "Activate")" asp-route-id="@tenant.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-warning">@(tenant.IsActive ? "Deactivate" : "Activate")</button></form></td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>
