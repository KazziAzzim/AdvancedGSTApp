@model TenantDetailsViewModel
@{ ViewData["Title"] = "Tenant Details"; }
<div class="page-header"><div><span class="eyebrow">Tenant</span><h1>@Model.Tenant.BusinessName</h1><p>@Model.Tenant.GSTIN • @Model.Tenant.Email</p></div><a class="btn btn-outline-secondary" asp-action="Index">Back</a></div>
<div class="row g-3"><div class="col-lg-6"><div class="card"><div class="card-body"><h5>Business Details</h5><dl class="row"><dt class="col-4">Contact</dt><dd class="col-8">@Model.Tenant.ContactPersonName</dd><dt class="col-4">Address</dt><dd class="col-8">@Model.Tenant.Address, @Model.Tenant.City, @Model.Tenant.State @Model.Tenant.Pincode</dd><dt class="col-4">Status</dt><dd class="col-8"><span class="badge bg-@(Model.Tenant.IsActive ? "success" : "secondary")">@(Model.Tenant.IsActive ? "Active" : "Inactive")</span></dd></dl></div></div></div><div class="col-lg-6"><div class="card"><div class="card-body"><h5>Subscription</h5><p><strong>@(Model.CurrentSubscription?.SubscriptionPlan?.PlanName ?? Model.Tenant.SubscriptionPlan?.PlanName ?? "No Plan")</strong></p><p>Status: <span class="badge bg-info">@(Model.CurrentSubscription?.Status ?? "-")</span></p><p>Expires: @(Model.CurrentSubscription?.EndDate.ToString("dd MMM yyyy") ?? Model.Tenant.SubscriptionEndDate?.ToString("dd MMM yyyy"))</p></div></div></div></div>
<div class="card table-card mt-3"><div class="card-header"><strong>Payment History</strong></div><table class="table"><thead><tr><th>Invoice</th><th>Date</th><th>Amount</th><th>Status</th></tr></thead><tbody>@foreach(var p in Model.Payments){<tr><td>@p.InvoiceNumber</td><td>@p.PaymentDate.ToString("dd MMM yyyy")</td><td>@p.Amount.ToString("C")</td><td><span class="badge bg-success">@p.PaymentStatus</span></td></tr>}</tbody></table></div>
