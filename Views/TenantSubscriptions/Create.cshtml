@model TenantSubscriptionViewModel
@{ ViewData["Title"] = "Assign Subscription"; }
<h1>Assign / Renew Subscription</h1>
<form method="post" class="card form-card"><div class="card-body row g-3"><div class="col-md-4"><label class="form-label">Tenant</label><select asp-for="TenantId" asp-items="ViewBag.Tenants" class="form-select"></select></div><div class="col-md-4"><label class="form-label">Plan</label><select asp-for="SubscriptionPlanId" asp-items="ViewBag.Plans" class="form-select"></select></div><div class="col-md-4"><label asp-for="BillingCycle" class="form-label"></label><input asp-for="BillingCycle" class="form-control" /></div><div class="col-md-3"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" type="date" class="form-control" /></div><div class="col-md-2"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" /></div><div class="col-md-2"><label asp-for="Status" class="form-label"></label><select asp-for="Status" class="form-select"><option>Trial</option><option>Active</option><option>Expired</option><option>Cancelled</option><option>Suspended</option></select></div><div class="col-md-2"><label asp-for="PaymentStatus" class="form-label"></label><select asp-for="PaymentStatus" class="form-select"><option>Pending</option><option>Paid</option><option>Failed</option></select></div></div><div class="card-footer"><button class="btn btn-primary">Save</button></div></form>
