@model SaasPaymentViewModel
@{ ViewData["Title"] = "Record SaaS Payment"; }
<h1>Record SaaS Payment</h1>
<form method="post" class="card form-card"><div class="card-body row g-3"><div class="col-md-4"><label class="form-label">Tenant</label><select asp-for="TenantId" asp-items="ViewBag.Tenants" class="form-select"></select></div><div class="col-md-4"><label class="form-label">Plan</label><select asp-for="SubscriptionPlanId" asp-items="ViewBag.Plans" class="form-select"></select></div><div class="col-md-4"><label asp-for="InvoiceNumber" class="form-label"></label><input asp-for="InvoiceNumber" class="form-control" /></div><div class="col-md-3"><label asp-for="PaymentDate" class="form-label"></label><input asp-for="PaymentDate" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" /></div><div class="col-md-3"><label asp-for="PaymentMode" class="form-label"></label><input asp-for="PaymentMode" class="form-control" /></div><div class="col-md-3"><label asp-for="PaymentStatus" class="form-label"></label><select asp-for="PaymentStatus" class="form-select"><option>Paid</option><option>Pending</option><option>Failed</option></select></div><div class="col-md-6"><label asp-for="TransactionReference" class="form-label"></label><input asp-for="TransactionReference" class="form-control" /></div><div class="col-md-6"><label asp-for="Notes" class="form-label"></label><input asp-for="Notes" class="form-control" /></div></div><div class="card-footer"><button class="btn btn-primary">Record</button></div></form>
