@model Customer
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Customer" : "Edit Customer";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Customer profile</div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">Capture buyer registration, contact, and billing details for compliant GST invoicing.</p>
    </div>
</div>

<form asp-action="Edit" method="post" class="section-card">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="CustomerName" class="form-label"></label>
            <input asp-for="CustomerName" class="form-control" />
            <span asp-validation-for="CustomerName" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="GSTIN" class="form-label"></label>
            <input asp-for="GSTIN" class="form-control gstin" />
        </div>
        <div class="col-md-3">
            <label asp-for="PANNumber" class="form-label"></label>
            <input asp-for="PANNumber" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="BillingAddress" class="form-label"></label>
            <textarea asp-for="BillingAddress" class="form-control" rows="4"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="ShippingAddress" class="form-label"></label>
            <textarea asp-for="ShippingAddress" class="form-control" rows="4"></textarea>
        </div>
        <div class="col-md-4">
            <label asp-for="State" class="form-label"></label>
            <input asp-for="State" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <button class="btn btn-primary"><i class="bi bi-save"></i> Save Customer</button>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</form>
