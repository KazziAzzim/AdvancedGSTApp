@model Customer
<h1>Customer</h1><form asp-action="Edit" method="post"><input asp-for="Id" type="hidden"/><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="row"><div class="col-md-6 mb-3"><label asp-for="CustomerName"></label><input asp-for="CustomerName" class="form-control"/><span asp-validation-for="CustomerName" class="text-danger"></span></div><div class="col-md-3 mb-3"><label asp-for="GSTIN"></label><input asp-for="GSTIN" class="form-control gstin"/></div><div class="col-md-3 mb-3"><label asp-for="PANNumber"></label><input asp-for="PANNumber" class="form-control"/></div><div class="col-md-6 mb-3"><label asp-for="BillingAddress"></label><textarea asp-for="BillingAddress" class="form-control"></textarea></div><div class="col-md-6 mb-3"><label asp-for="ShippingAddress"></label><textarea asp-for="ShippingAddress" class="form-control"></textarea></div><div class="col-md-4 mb-3"><label asp-for="State"></label><input asp-for="State" class="form-control"/></div><div class="col-md-4 mb-3"><label asp-for="City"></label><input asp-for="City" class="form-control"/></div><div class="col-md-4 mb-3"><label asp-for="Email"></label><input asp-for="Email" class="form-control"/></div></div><button class="btn btn-primary">Save</button></form>
