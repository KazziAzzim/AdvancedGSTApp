@model IEnumerable<Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Master data</div>
        <h1 class="page-title">Customers</h1>
        <p class="page-subtitle">Manage GSTIN, PAN, billing, shipping, and contact information for buyers.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle"></i> Add Customer</a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-modern data-table">
            <thead><tr><th>Name</th><th>GSTIN</th><th>State</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td class="fw-bold">@customer.CustomerName</td>
                        <td><span class="badge bg-light text-dark">@customer.GSTIN</span></td>
                        <td>@customer.State</td>
                        <td class="text-end">
                            <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@customer.Id"><i class="bi bi-pencil-square"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@customer.Id" method="post" class="d-inline delete-form">
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
