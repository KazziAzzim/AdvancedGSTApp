@model UserListViewModel
@{ ViewData["Title"] = "User Management"; }
<div class="d-flex justify-content-between align-items-start mb-4">
  <div><h1 class="h3 mb-1">User Management</h1><p class="text-muted mb-0">Create users, assign roles, and control account access.</p></div>
  <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add User</a>
</div>
<form class="card border-0 shadow-sm mb-4"><div class="card-body row g-3">
  <div class="col-md-4"><input name="search" value="@Model.Search" class="form-control" placeholder="Search name, email, phone" /></div>
  <div class="col-md-3"><select name="roleId" asp-items="Model.Roles" class="form-select"><option value="">All roles</option></select></div>
  <div class="col-md-3"><select name="isActive" class="form-select"><option value="">All statuses</option><option value="true" selected="@(Model.IsActive == true)">Active</option><option value="false" selected="@(Model.IsActive == false)">Inactive</option></select></div>
  <div class="col-md-2"><button class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Filter</button></div>
</div></form>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table align-middle mb-0">
<thead class="table-light"><tr><th>Full Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Status</th><th>Last Login</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
<tbody>
@foreach (var user in Model.Users) {
<tr>
<td class="fw-semibold">@user.FullName</td><td>@user.Email</td><td>@user.PhoneNumber</td><td><span class="badge text-bg-info">@user.Role</span></td>
<td><span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">@(user.IsActive ? "Active" : "Inactive")</span></td>
<td>@(user.LastLoginDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Never")</td><td>@user.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</td>
<td class="text-end"><div class="btn-group btn-group-sm">
<a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
<a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
<a asp-action="ChangePassword" asp-route-id="@user.Id" class="btn btn-outline-warning" title="Change Password"><i class="bi bi-key"></i></a>
<form asp-action="@(user.IsActive ? "Deactivate" : "Activate")" asp-route-id="@user.Id" method="post" class="d-inline"><button class="btn btn-outline-@(user.IsActive ? "secondary" : "success")" onclick="return confirm('Are you sure?')"><i class="bi @(user.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i></button></form>
<form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"><button class="btn btn-outline-danger" onclick="return confirm('Delete/deactivate this user?')"><i class="bi bi-trash"></i></button></form>
</div></td></tr>
}
</tbody></table></div></div>
@if (Model.TotalPages > 1) { <nav class="mt-3"><ul class="pagination">@for (var i=1;i<=Model.TotalPages;i++){<li class="page-item @(i==Model.Page?"active":"")"><a class="page-link" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-roleId="@Model.RoleId" asp-route-isActive="@Model.IsActive">@i</a></li>}</ul></nav> }
