@model UserDetailsViewModel
@{ ViewData["Title"] = "User Details"; }
<div class="d-flex justify-content-between mb-4"><div><h1 class="h3">User Details</h1><p class="text-muted">Review account status and role assignment.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Back</a></div>
<div class="card border-0 shadow-sm"><div class="card-body row g-3">
<div class="col-md-6"><strong>Full Name</strong><div>@Model.FullName</div></div><div class="col-md-6"><strong>Email</strong><div>@Model.Email</div></div>
<div class="col-md-6"><strong>Username</strong><div>@Model.UserName</div></div><div class="col-md-6"><strong>Phone</strong><div>@Model.PhoneNumber</div></div>
<div class="col-md-6"><strong>Role</strong><div><span class="badge text-bg-info">@Model.RoleName</span></div></div><div class="col-md-6"><strong>Status</strong><div><span class="badge @(Model.IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></div></div>
<div class="col-md-4"><strong>Created</strong><div>@Model.CreatedDate.ToLocalTime()</div></div><div class="col-md-4"><strong>Updated</strong><div>@Model.UpdatedDate?.ToLocalTime()</div></div><div class="col-md-4"><strong>Last Login</strong><div>@(Model.LastLoginDate?.ToLocalTime().ToString() ?? "Never")</div></div>
</div><div class="card-footer bg-white"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a></div></div>
