@model ChangeUserPasswordViewModel
@{ ViewData["Title"] = "Change User Password"; }
<div class="d-flex justify-content-between mb-4"><div><h1 class="h3">Change Password</h1><p class="text-muted">Reset password for @Model.FullName. Passwords are hashed by ASP.NET Core Identity.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Back</a></div>
<form asp-action="ChangePassword" method="post" class="card border-0 shadow-sm"><input asp-for="Id" type="hidden"/><input asp-for="FullName" type="hidden"/><div class="card-body row g-3">
<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-6"><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control"/><span asp-validation-for="Password" class="text-danger"></span></div><div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control"/><span asp-validation-for="ConfirmPassword" class="text-danger"></span></div>
</div><div class="card-footer bg-white text-end"><button class="btn btn-warning"><i class="bi bi-key"></i> Change Password</button></div></form>
