@model IEnumerable<Gstr1RowViewModel>
<h1>GSTR-1</h1><table class="table table-bordered"><thead><tr><th>Invoice</th><th>Date</th><th>GSTIN</th><th>Customer</th><th>Taxable</th><th>CGST</th><th>SGST</th><th>IGST</th><th>Total</th><th>Status</th></tr></thead><tbody>@foreach(var r in Model){<tr><td>@r.InvoiceNumber</td><td>@r.InvoiceDate.ToShortDateString()</td><td>@r.CustomerGSTIN</td><td>@r.CustomerName</td><td>@r.TaxableAmount</td><td>@r.CGST</td><td>@r.SGST</td><td>@r.IGST</td><td>@r.InvoiceTotal</td><td><span class="badge bg-info">@r.EInvoiceStatus</span></td></tr>}</tbody></table><form asp-action="PrepareReturn" method="post"><input type="hidden" name="returnType" value="GSTR-1"/><input name="month" value="6" type="hidden"/><input name="financialYear" value="2026-27" type="hidden"/><button class="btn btn-primary">Prepare GSTR-1</button></form>
