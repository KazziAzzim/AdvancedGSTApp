@model Gstr3BViewModel
<h1>GSTR-3B</h1><table class="table"><tr><th>Outward taxable supplies</th><td>@Model.OutwardTaxableSupplies</td></tr><tr><th>Output CGST/SGST/IGST</th><td>@Model.OutputCGST / @Model.OutputSGST / @Model.OutputIGST</td></tr><tr><th>Eligible ITC</th><td>@Model.EligibleITC</td></tr><tr><th>Input CGST/SGST/IGST</th><td>@Model.InputCGST / @Model.InputSGST / @Model.InputIGST</td></tr><tr><th>Net tax payable</th><td>@Model.NetTaxPayable</td></tr></table><form asp-action="PrepareReturn" method="post"><input type="hidden" name="returnType" value="GSTR-3B"/><input name="month" value="6" type="hidden"/><input name="financialYear" value="2026-27" type="hidden"/><button class="btn btn-primary">Prepare GSTR-3B</button></form>
