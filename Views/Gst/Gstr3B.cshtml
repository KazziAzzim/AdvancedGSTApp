@model Gstr3BViewModel
@{
    ViewData["Title"] = "GSTR-3B";
}

<div class="page-header">
    <div><div class="page-kicker">Monthly return</div><h1 class="page-title">GSTR-3B</h1><p class="page-subtitle">Summarized outward tax, input tax credit, and net GST payable details.</p></div>
    <form asp-action="PrepareReturn" method="post"><input type="hidden" name="returnType" value="GSTR-3B" /><input name="month" value="6" type="hidden" /><input name="financialYear" value="2026-27" type="hidden" /><button class="btn btn-primary"><i class="bi bi-clipboard2-check"></i> Prepare GSTR-3B</button></form>
</div>

<div class="section-card">
    <div class="table-responsive">
        <table class="table table-modern">
            <tbody>
                <tr><th>Outward taxable supplies</th><td class="fw-bold">₹@Model.OutwardTaxableSupplies</td></tr>
                <tr><th>Output CGST / SGST / IGST</th><td>@Model.OutputCGST / @Model.OutputSGST / @Model.OutputIGST</td></tr>
                <tr><th>Eligible ITC</th><td><span class="badge bg-success">₹@Model.EligibleITC</span></td></tr>
                <tr><th>Input CGST / SGST / IGST</th><td>@Model.InputCGST / @Model.InputSGST / @Model.InputIGST</td></tr>
                <tr class="grand-total"><th>Net tax payable</th><td class="fw-bold fs-5">₹@Model.NetTaxPayable</td></tr>
            </tbody>
        </table>
    </div>
</div>
