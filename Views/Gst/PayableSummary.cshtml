@model GstPayableSummaryViewModel
<h1>GST Payable Summary</h1><div class="row g-3"><div class="col-md-4"><div class="card"><div class="card-body"><h5>Output CGST</h5><h3>@Model.OutputCGST</h3></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Output SGST</h5><h3>@Model.OutputSGST</h3></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Output IGST</h5><h3>@Model.OutputIGST</h3></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Input CGST</h5><h3>@Model.InputCGST</h3></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Input SGST</h5><h3>@Model.InputSGST</h3></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><h5>Input IGST</h5><h3>@Model.InputIGST</h3></div></div></div></div><div class="alert alert-primary mt-3"><strong>Total GST Payable:</strong> ₹@Model.TotalGstPayable.ToString("N2")</div>
