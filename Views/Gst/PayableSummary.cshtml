@model GstPayableSummaryViewModel
@{
    ViewData["Title"] = "GST Payable Summary";
}

<div class="page-header">
    <div><div class="page-kicker">Tax position</div><h1 class="page-title">GST Payable Summary</h1><p class="page-subtitle">Compare output tax and input tax credit in a clean compliance dashboard.</p></div>
</div>

<div class="row g-3">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-up-right"></i></div><span class="stat-label">Output CGST</span><h3 class="stat-value">₹@Model.OutputCGST</h3></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-up-right"></i></div><span class="stat-label">Output SGST</span><h3 class="stat-value">₹@Model.OutputSGST</h3></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-up-right"></i></div><span class="stat-label">Output IGST</span><h3 class="stat-value">₹@Model.OutputIGST</h3></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-down-left"></i></div><span class="stat-label">Input CGST</span><h3 class="stat-value">₹@Model.InputCGST</h3></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-down-left"></i></div><span class="stat-label">Input SGST</span><h3 class="stat-value">₹@Model.InputSGST</h3></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon"><i class="bi bi-arrow-down-left"></i></div><span class="stat-label">Input IGST</span><h3 class="stat-value">₹@Model.InputIGST</h3></div></div>
</div>

<div class="section-card grand-total mt-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div><div class="page-kicker mb-1">Net liability</div><h3 class="mb-0">Total GST Payable</h3></div>
        <h2 class="mb-0">₹@Model.TotalGstPayable.ToString("N2")</h2>
    </div>
</div>
